# Copy to .env for local dev, or set these as Environment Variables in Vercel.
# NEVER commit real values — .env is gitignored.

# Calendly — read-only availability (scopes: availability:read, event_types:read, users:read)
CALENDLY_ACCESS_TOKEN=your_calendly_personal_access_token
CALENDLY_EVENT_TYPE_URI=https://api.calendly.com/event_types/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Telegram — manager notifications (@gocoding_leads_bot)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=-1000000000000

# Google Apps Script web app — booking sheet (counts + lead writes)
GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/XXXXXXXX/exec
